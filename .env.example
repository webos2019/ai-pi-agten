# DeepSeek API 配置 (兼容 OpenAI 接口)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Embedding API 配置 (长期记忆向量化)
# 可独立配置，也可回退到 DeepSeek 配置
# 注意: DeepSeek 不提供 embedding 接口，需使用其他 OpenAI 兼容的 embedding 服务
# 例如: OpenAI text-embedding-3-small / 智谱 embedding-2 / 通义 text-embedding-v2 等
EMBEDDING_API_KEY=your_embedding_api_key_here
EMBEDDING_API_BASE=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1024
